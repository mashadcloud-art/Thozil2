# ─── Database ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/thozil_db

# ─── App ────────────────────────────────────────────────────────────────────
BASE_URL=https://thozil.com
PORT=5000

# ─── Image API Keys ─────────────────────────────────────────────────────────

# 1. Pexels — https://www.pexels.com/api/
#    Free, 200 req/hour, attribution required (photographer name)
PEXELS_API_KEY=your_pexels_key_here

# 2. Pixabay — https://pixabay.com/api/docs/
#    Free, 100 req/min, no attribution required (but show source in UI)
#    YOUR KEY (from https://pixabay.com/api/docs/ when logged in):
PIXABAY_API_KEY=51370253-b8c3c342aba7d34df5e4b6923

# 3. Unsplash — https://unsplash.com/developers
#    Free (demo: 50 req/hour), attribution required (photographer + "on Unsplash")
#    Get key from: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# NOTE: Wikimedia Commons needs no key — it works automatically.
